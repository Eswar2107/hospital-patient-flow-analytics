{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "hospital-analytics-df-21"
		},
		"storagehospital_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'storagehospital'"
		},
		"Hospitaldatabricks_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0326-073933-nfkv8haz"
		},
		"hospital-vault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://hospitalvault21.vault.azure.net/"
		},
		"storagehospital_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://hospitalanalytics21.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "hospital-analytics-df-21_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"storagehospital_accountKey": {
						"value": "[parameters('storagehospital_accountKey')]"
					},
					"hospital-vault_properties_typeProperties_baseUrl": {
						"value": "[parameters('hospital-vault_properties_typeProperties_baseUrl')]"
					},
					"storagehospital_properties_typeProperties_url": {
						"value": "[parameters('storagehospital_properties_typeProperties_url')]"
					},
					"Hospitaldatabricks_properties_typeProperties_existingClusterId": {
						"value": "[parameters('Hospitaldatabricks_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}